# ─── LLM Configuration ───
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ─── Application ───
LOG_LEVEL=INFO
OUTPUT_DIR=outputs
MAX_REEVAL_ITERATIONS=3
TARGET_SCORE=90

# ─── Auth ───
AUTH_ENABLED=False
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://smartuser:smartpass@localhost:5432/smart_resume
DB_ECHO=False
